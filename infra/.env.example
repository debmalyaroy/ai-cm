# =============================================================================
# AI-CM Environment Configuration
# Copy this file to .env and fill in the values
# =============================================================================

# --- LLM Provider ---
# Choose: "gemini", "openai", "aws", or "local"
# For local development with Ollama, use "local"
LLM_PROVIDER=gemini

# --- Gemini (if LLM_PROVIDER=gemini) ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# --- OpenAI (if LLM_PROVIDER=openai) ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# --- AWS Bedrock (if LLM_PROVIDER=aws) ---
AWS_REGION=us-east-1
AWS_BEDROCK_MODEL=anthropic.claude-3-haiku-20240307-v1:0
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# --- Local LLM / Ollama (if LLM_PROVIDER=local) ---
# IMPORTANT: Use "ollama" (Docker service name) NOT "localhost" when running via Docker Compose.
# Use "localhost" only when running the backend natively outside Docker.
LOCAL_LLM_URL=http://ollama:11434/api/generate
LOCAL_LLM_MODEL=llama3.2

# --- Postgres ---
POSTGRES_USER=aicm
POSTGRES_PASSWORD=aicm_secret
POSTGRES_DB=aicm
POSTGRES_PORT=5432

# --- Backend ---
BACKEND_PORT=8080

# --- Frontend ---
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8080
