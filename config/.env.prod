# AI-CM Production Environment
# Copy this file, fill in all values, and keep it secret (never commit to git).
# Usage: ./scripts/deploy_e2e.sh prod  (reads this file automatically)

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── LLM Provider ─────────────────────────────────────────────────────────────
LLM_PROVIDER=aws

# ── Database (RDS) ───────────────────────────────────────────────────────────
# Replace the placeholders below with your actual RDS values.
POSTGRES_USER=aicm
POSTGRES_PASSWORD=your_rds_password_here
POSTGRES_DB=aicm
# Full connection string — env var takes precedence over config.prod.yaml
DATABASE_URL=postgres://aicm:your_rds_password_here@your-rds-endpoint.us-east-1.rds.amazonaws.com:5432/aicm?sslmode=require

# ── AWS ───────────────────────────────────────────────────────────────────────
# EC2 instances use an IAM role — no static keys needed on EC2.
# Only set ACCESS_KEY/SECRET if running outside EC2 (e.g., local prod smoke-test).
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── EC2 / RDS Instance IDs (used by aws_startstop.sh / aws_startstop.ps1) ───
# Fill these in after creating your EC2 and RDS instances in the AWS Console.
EC2_INSTANCE_ID=i-0123456789abcdef0
RDS_INSTANCE_ID=aicm-postgres

# ── Docker Registry (DockerHub) ───────────────────────────────────────────────
# Your DockerHub username — used if pulling pre-built images.
DOCKER_REGISTRY=your_dockerhub_username

# ── Frontend URLs ─────────────────────────────────────────────────────────────
# Public URL where the app is reachable (Elastic IP or custom domain).
# nginx handles routing: frontend on / and backend API on /api/
NEXT_PUBLIC_API_URL=http://your-ec2-elastic-ip
# Internal URL used by Next.js server-side routes to reach the backend container.
INTERNAL_API_URL=http://backend:8080
