# AI-CM Production Environment Template
# Define your production keys and values here

# Backend Logger Config
LOG_LEVEL=INFO

# LLM Selection (Usually 'aws', 'openai', or 'gemini' for prod)
LLM_PROVIDER=aws

# Production DB Secrets (must match RDS or hosted DB)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secure_password_here
POSTGRES_DB=ai_cm
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@your-db-host:5432/${POSTGRES_DB}?sslmode=require

# AWS Bedrock/ECR Details
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Docker Registry location
DOCKER_REGISTRY=your-docker-registry

# Endpoints
NEXT_PUBLIC_API_URL=https://your-domain.com/api
