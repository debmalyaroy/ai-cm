# Environment variables for AI-CM Backend

# LLM Provider Configuration
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# AWS Configuration (Do not commit real credentials!)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# Bedrock specific (if using AWS Bedrock as an LLM provider)
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# Database
DATABASE_URL=postgres://aicm:aicm_secret@localhost:5432/aicm?sslmode=disable

# Security / Rate Limiting
API_KEY_AUTH_ENABLED=true
API_KEYS=key1,key2
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100

# Other
PROMPT_DIR=../prompts
PORT=8080
LOG_LEVEL=debug
