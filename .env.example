# ==============================================================================
# AI-CM Environment Configuration
# ==============================================================================
# This file contains configuration grouped by deployment profiles.
# The unified scripts (`run.sh/ps1`, `deploy.sh/ps1`) parse this file to
# inject the appropriate environment variables for the selected profile.
#
# DO NOT COMMIT THIS FILE TO VERSION CONTROL IF IT CONTAINS SECRETS.
# ==============================================================================


# ------------------------------------------------------------------------------
# [local.local]
# Local execution using Dockerized Ollama as the LLM provider.
# Requires a dedicated GPU on the host. Route config for Ollama is auto-applied.
# ------------------------------------------------------------------------------
# ------------------------------------------------------------------------------
[local.local]
POSTGRES_USER=aicm               # Default Postgres user in the docker container
POSTGRES_PASSWORD=aicm_secret    # Default Postgres password in the docker container

# ------------------------------------------------------------------------------
# [local.aws]
# Local execution using AWS Bedrock as the LLM provider.
# Ideal for laptops without a heavy dedicated GPU.
# ------------------------------------------------------------------------------
[local.aws]
POSTGRES_USER=aicm               # Default Postgres user in the docker container
POSTGRES_PASSWORD=aicm_secret    # Default Postgres password in the docker container
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY


# ------------------------------------------------------------------------------
# [prod.aws]
# Production execution targeting an AWS EC2 instance + RDS database.
# ------------------------------------------------------------------------------
[prod.aws]
POSTGRES_USER=aicm
POSTGRES_PASSWORD=YOUR_PROD_RDS_PASSWORD
POSTGRES_DB=aicm

# DockerHub Registry settings (required to push/pull Docker images)
# How to create a PAT: hub.docker.com -> Account Settings -> Security -> Access Tokens
#   Set name: github-actions-aicm, scope: Read & Write
# To push images locally:   .scripts\build.ps1 all -Target prod
# To push images on Linux:  ./scripts/build.sh all -t prod
# Docker login is called automatically by the build script when -Target prod is used.
DOCKER_REGISTRY=YOUR_DOCKERHUB_USERNAME   # e.g. debmalyaroy — used as image prefix
DOCKER_USERNAME=YOUR_DOCKERHUB_USERNAME   # same value as DOCKER_REGISTRY
DOCKER_PAT=YOUR_DOCKERHUB_PAT             # Personal Access Token (starts with dckr_pat_)

# EC2 Start/Stop script identifiers
EC2_INSTANCE_ID=i-0123456789abcdef0
RDS_INSTANCE_ID=aicm-postgres
